# Entorno
NODE_ENV=development
PORT=3000

# Base de datos
DATABASE_URL=postgresql://velytics:velytics@localhost:5433/velytics?schema=public

# JWT (RS256). Genera un par de claves con:
#   openssl genpkey -algorithm RSA -pkeyopt rsa_keygen_bits:2048 -out private.pem
#   openssl rsa -pubout -in private.pem -out public.pem
#   base64 -w0 private.pem
#   base64 -w0 public.pem
# En producción (Render) usa JWT_PRIVATE_KEY_FILE / JWT_PUBLIC_KEY_FILE apuntando
# a Render Secret Files en vez de las variables _B64.
JWT_ISSUER=http://localhost:3000
JWT_PRIVATE_KEY_B64=
JWT_PUBLIC_KEY_B64=
JWT_ACCESS_TTL_SECONDS=900
JWT_REFRESH_TTL_DAYS=7

# CORS (orígenes separados por coma)
CORS_ALLOWED_ORIGINS=http://localhost:4200

# Rate limiting de /api/v1/auth/**
THROTTLE_AUTH_LIMIT=10
THROTTLE_AUTH_TTL_SECONDS=60

# Usuario administrador sembrado al arrancar
ADMIN_USERNAME=admin
ADMIN_PASSWORD=Admin123!
ADMIN_EMAIL=admin@velytics.local
ADMIN_FIRST_NAME=Admin
ADMIN_LAST_NAME=Velytics
ADMIN_NATIONAL_ID=1000000000
ADMIN_PHONE_NUMBER=3000000000

# Clave compartida para llamadas servicio-a-servicio (p. ej. la API de ML)
SERVICE_API_KEY=change-me-to-a-random-string-of-at-least-32-chars

# AWS S3 (imágenes de vehículos)
AWS_REGION=us-east-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=
S3_UPLOAD_URL_TTL_SECONDS=600
S3_DOWNLOAD_URL_TTL_SECONDS=900
# Max declared/actual image size accepted (ASVS V5.2.1). Default: 10 MB.
S3_MAX_IMAGE_SIZE_BYTES=10485760

# Caché del dashboard
DASHBOARD_CACHE_TTL_SECONDS=60
